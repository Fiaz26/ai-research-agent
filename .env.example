# ================================================================
# AI Research Agent — Environment Variables
# Copy this file to .env and fill in your values
# ================================================================

# ── Database (required) ─────────────────────────────────────────
# Free PostgreSQL: https://neon.tech  (no credit card needed)
DATABASE_URL=postgresql://user:password@host/dbname

# ── AI Provider (choose ONE) ────────────────────────────────────

# Option A: Google Gemini — FREE tier, recommended
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Option B: OpenAI
# Get key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here

# Option C: Custom OpenAI-compatible API (Groq, Together, etc.)
# OPENAI_API_KEY=your-api-key-here
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# ── Override the AI model (optional) ───────────────────────────
# Gemini default: gemini-2.0-flash
# OpenAI default: gpt-4o
# AI_MODEL=gemini-2.0-flash

# ── Session secret (required) ──────────────────────────────────
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# ── App port (optional, default 5000) ──────────────────────────
# PORT=5000
